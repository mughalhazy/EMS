# ──────────────────────────────────────────────────────────────
# EMS Web — Environment Variables
# Copy to .env.local for local development.
# ──────────────────────────────────────────────────────────────

# URL of the NestJS API server.
# Next.js rewrites /api/v1/* → ${NEXT_PUBLIC_API_URL}/api/v1/*
# REQUIRED in production; defaults to http://localhost:3001 locally.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Public URL of this Next.js app (used for absolute URL generation).
NEXT_PUBLIC_APP_URL=http://localhost:3000
