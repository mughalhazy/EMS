{
  "id": "notifications-v1",
  "version": "ui-renderer-spec/v1",
  "surface": "app",
  "meta": {
    "title": "Notifications",
    "route": "/notifications",
    "description": "Platform notification log with status filtering",
    "roles": ["admin", "manager"]
  },
  "regions": {
    "top": {
      "layout": "stack",
      "gap": "sm",
      "blocks": [
        {
          "id": "notifications-header",
          "type": "page_header",
          "order": 0,
          "props": {
            "title": "Notifications",
            "subtitle": "Platform notification log"
          }
        }
      ]
    },
    "filters": {
      "layout": "stack",
      "gap": "sm",
      "blocks": [
        {
          "id": "status-filter",
          "type": "tabset",
          "order": 0,
          "props": {
            "tabs": ["All", "Sent", "Pending", "Failed"],
            "dataKey": "statusFilter"
          },
          "annotations": {
            "aria-label": "Notification status filter"
          }
        }
      ]
    },
    "primary": {
      "layout": "grid",
      "gap": "md",
      "blocks": [
        {
          "id": "notifications-table",
          "type": "list_table",
          "order": 0,
          "span": 12,
          "props": {
            "dataKey": "notifications",
            "pageSize": 25,
            "columns": ["channel", "template", "subject", "status", "sentAt"]
          },
          "states": {
            "loading": { "id": "notifications-table-skeleton", "type": "loading_placeholder" },
            "empty":   { "id": "notifications-table-empty",   "type": "empty_placeholder" }
          }
        }
      ]
    }
  }
}
