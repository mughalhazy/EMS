{
  "id": "attendees-v1",
  "version": "ui-renderer-spec/v1",
  "surface": "app",
  "meta": {
    "title": "Attendees",
    "route": "/attendees",
    "description": "Attendee directory and check-in status per event",
    "roles": ["admin", "manager", "checkin_staff"]
  },
  "regions": {
    "top": {
      "layout": "stack",
      "gap": "sm",
      "blocks": [
        {
          "id": "attendees-header",
          "type": "page_header",
          "order": 0,
          "props": {
            "title": "Attendees",
            "subtitle": "Directory and check-in status"
          }
        }
      ]
    },
    "filters": {
      "layout": "stack",
      "gap": "sm",
      "blocks": [
        {
          "id": "event-selector",
          "type": "select_input",
          "order": 0,
          "span": 4,
          "props": {
            "dataKey": "eventId",
            "label": "Event",
            "placeholder": "Select event…"
          }
        },
        {
          "id": "status-filter",
          "type": "tabset",
          "order": 1,
          "props": {
            "tabs": ["All", "Registered", "Checked In", "Prospect", "Cancelled"],
            "dataKey": "statusFilter"
          },
          "annotations": {
            "aria-label": "Attendee status filter"
          }
        }
      ]
    },
    "primary": {
      "layout": "grid",
      "gap": "md",
      "blocks": [
        {
          "id": "attendees-table",
          "type": "list_table",
          "order": 0,
          "span": 12,
          "props": {
            "dataKey": "attendees",
            "pageSize": 25,
            "columns": ["avatar", "name", "email", "status", "checkedInAt", "actions"]
          },
          "states": {
            "loading": { "id": "attendees-table-skeleton", "type": "loading_placeholder" },
            "empty":   { "id": "attendees-table-empty",   "type": "empty_placeholder" }
          }
        }
      ]
    }
  }
}
