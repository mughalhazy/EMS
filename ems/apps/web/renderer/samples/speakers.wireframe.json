{
  "id": "speakers-v1",
  "version": "ui-renderer-spec/v1",
  "surface": "app",
  "meta": {
    "title": "Speakers",
    "route": "/speakers",
    "description": "Speaker roster and status per event",
    "roles": ["admin", "manager"]
  },
  "regions": {
    "top": {
      "layout": "stack",
      "gap": "sm",
      "blocks": [
        {
          "id": "speakers-header",
          "type": "page_header",
          "order": 0,
          "props": {
            "title": "Speakers",
            "subtitle": "Speaker roster and confirmation status"
          }
        }
      ]
    },
    "filters": {
      "layout": "stack",
      "gap": "sm",
      "blocks": [
        {
          "id": "event-selector",
          "type": "select_input",
          "order": 0,
          "span": 4,
          "props": {
            "dataKey": "eventId",
            "label": "Event",
            "placeholder": "Select event…"
          }
        },
        {
          "id": "status-filter",
          "type": "tabset",
          "order": 1,
          "props": {
            "tabs": ["All", "Confirmed", "Invited", "Declined", "Withdrawn"],
            "dataKey": "statusFilter"
          },
          "annotations": {
            "aria-label": "Speaker status filter"
          }
        }
      ]
    },
    "primary": {
      "layout": "grid",
      "gap": "md",
      "blocks": [
        {
          "id": "speakers-table",
          "type": "list_table",
          "order": 0,
          "span": 12,
          "props": {
            "dataKey": "speakers",
            "pageSize": 25,
            "columns": ["avatar", "name", "bio", "status", "actions"]
          },
          "states": {
            "loading": { "id": "speakers-table-skeleton", "type": "loading_placeholder" },
            "empty":   { "id": "speakers-table-empty",   "type": "empty_placeholder" }
          }
        }
      ]
    }
  }
}
