{
  "id": "sponsors-v1",
  "version": "ui-renderer-spec/v1",
  "surface": "app",
  "meta": {
    "title": "Sponsors",
    "route": "/sponsors",
    "description": "Sponsor management per event",
    "roles": ["admin", "manager"]
  },
  "regions": {
    "top": {
      "layout": "stack",
      "gap": "sm",
      "blocks": [
        {
          "id": "sponsors-header",
          "type": "page_header",
          "order": 0,
          "props": {
            "title": "Sponsors",
            "subtitle": "Sponsor partnerships and tiers"
          }
        }
      ]
    },
    "filters": {
      "layout": "stack",
      "gap": "sm",
      "blocks": [
        {
          "id": "event-selector",
          "type": "select_input",
          "order": 0,
          "span": 4,
          "props": {
            "dataKey": "eventId",
            "optionsKey": "events",
            "label": "Event",
            "placeholder": "Select event…"
          }
        },
        {
          "id": "status-filter",
          "type": "tabset",
          "order": 1,
          "props": {
            "tabs": ["All", "Active", "Pending", "Inactive"],
            "dataKey": "statusFilter"
          },
          "annotations": {
            "aria-label": "Sponsor status filter"
          }
        }
      ]
    },
    "primary": {
      "layout": "grid",
      "gap": "md",
      "blocks": [
        {
          "id": "sponsors-table",
          "type": "list_table",
          "order": 0,
          "span": 12,
          "props": {
            "dataKey": "sponsors",
            "pageSize": 25,
            "columns": ["organization", "tier", "amount", "status", "actions"]
          },
          "states": {
            "loading": { "id": "sponsors-table-skeleton", "type": "loading_placeholder" },
            "empty":   { "id": "sponsors-table-empty",   "type": "empty_placeholder" }
          }
        }
      ]
    }
  }
}
